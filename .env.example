NODE_ENV=production
DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/db
SESSION_SECRET=change-me-32+chars
SESSION_COOKIE_NAME=cristianhdz.sid

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Anthropic (optional — enables the Copilot)
ANTHROPIC_API_KEY=

# SMTP — required for password reset + welcome emails. Defaults assume a
# cPanel-style provider on port 465 with SSL. Override SMTP_SECURE=false +
# SMTP_PORT=587 if your provider uses STARTTLS instead.
SMTP_HOST=mail.cristianhdz.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@cristianhdz.com
SMTP_PASS=
MAIL_FROM=Cristian Hernández <info@cristianhdz.com>

# Optional: Resend HTTPS fallback when SMTP_HOST is not set
# RESEND_API_KEY=re_...

PUBLIC_SITE_URL=https://cristianhdz.com
